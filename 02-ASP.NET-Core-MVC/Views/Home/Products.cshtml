@{
    ViewData["Title"] = "صفحة المنتجات";
    string currentCategory = "الإلكترونيات";
}

<div class="container mt-5">
    <div class="jumbotron p-4 bg-light rounded shadow-sm">
        <h1 class="text-success display-4">أهلاً بك في صفحة المنتجات</h1>
        <p class="lead">
            أنت الآن تستعرض قسم
            <span class="badge bg-primary">@currentCategory</span>
        </p>
        <hr class="my-4">
        <div class="alert alert-info" role="alert">
            استمتع في المتجر، القوائم هنا للمنتجات بشكل ديناميكي ومرتب.
        </div>
    </div>
</div>